library(data.table)
# the tsv of KANSL1 mutations was downloaded from cBioPortal
mutations <- read.table('data/KANSL1_mutations.tsv')
# the tsv of KANSL1 mutations was downloaded from cBioPortal
mutations <- read.table('data/KANSL1_mutations.tsv', sep = '/t')
# the tsv of KANSL1 mutations was downloaded from cBioPortal
mutations <- read.table('data/KANSL1_mutations.tsv', sep = '\t')
# the tsv of KANSL1 mutations was downloaded from cBioPortal
mutations <- read.table('data/KANSL1_mutations.tsv', sep = '\t', header = TRUE)
# the tsv of KANSL1 mutations was downloaded from cBioPortal
mutations <- read.table('data/KANSL1_mutations.tsv', sep = '\t', header = FALSE)
# the tsv of KANSL1 mutations was downloaded from cBioPortal
mutations <- read.table('data/KANSL1_mutations.tsv', sep = '\t', header = TRUE, fill = TRUE)
# the tsv of KANSL1 mutations was downloaded from cBioPortal
mutations <- fread('data/KANSL1_mutations.tsv')
View(mutations)
# assign HGVsg values to vector
HGVSg <- mutations$HGVSg
# write txt
writeLines(HGVSg, 'outputs/HGVSg.txt')
HGVSc <- mutations$HGVSc
writeLines(HGVSc, 'outputs/HGVSc.txt')
View(dds_results)
