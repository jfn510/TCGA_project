gene_tots[grep('KANSL1', gene_tots$Hugo_Symbol),]$MutatedSamples
gene_tots[grep('KANSL1', gene_tots$Hugo_Symbol),]$AlteredSamples
# extract KANSL1 mutant patient IDs
